{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "nodeVersion": "20.x",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/handler.js"
    }
  ]
}
